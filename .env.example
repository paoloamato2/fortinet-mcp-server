# FortiOS MCP Server - Environment Variables
# Copy to .env and fill in your values

# FortiOS host (include https:// prefix)
FORTIOS_HOST=https://192.168.1.99

# API token (generate in FortiOS: System > Administrators > REST API Admin)
FORTIOS_API_TOKEN=your-api-token-here

# VDOM to target (default: root)
FORTIOS_VDOM=root

# Whether to verify the FortiOS SSL certificate (set to false for self-signed certs)
FORTIOS_VERIFY_SSL=false

# HTTP timeout in seconds
FORTIOS_TIMEOUT=30
